PORT=4000
NODE_ENV=development

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=roshan_blog_db
DB_USER=postgres
DB_PASSWORD=yourpassword

# JWT
JWT_SECRET=your_jwt_secret
JWT_REFRESH_SECRET=your_jwt_refresh_secret

# Public URL used to build media URLs (no trailing slash)
MEDIA_BASE_URL=http://localhost:4000

# Public app/API URLs used in newsletter links (no trailing slash)
APP_BASE_URL=http://localhost:3000
API_BASE_URL=http://localhost:4000

# Newsletter email provider
RESEND_API_KEY=your_resend_api_key
EMAIL_FROM="Roshan Blog <newsletter@your-verified-domain.com>"
NEWSLETTER_EMAIL_RATE_LIMIT_PER_SECOND=2

# Admin seeder (required by db:seed-admin)
ADMIN_NAME=Admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=SecretPassword123
