PORT=4000
NODE_ENV=development

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=your_db_name
DB_USER=your_db_user
DB_PASSWORD=your_db_password

# JWT (use long random strings in production)
JWT_SECRET=your_jwt_secret
JWT_REFRESH_SECRET=your_jwt_refresh_secret

# Public URL used to build media URLs (no trailing slash)
MEDIA_BASE_URL=http://localhost:4000

# Public app/API URLs used in newsletter links (no trailing slash)
APP_BASE_URL=http://localhost:3000
API_BASE_URL=http://localhost:4000

# Allowed frontend origin for CORS
FRONTEND_URL=http://localhost:3000

# Newsletter email provider
RESEND_API_KEY=your_resend_api_key
EMAIL_FROM="Your Blog <newsletter@your-verified-domain.com>"
NEWSLETTER_EMAIL_RATE_LIMIT_PER_SECOND=2

# Contact form — email address that receives contact form submissions
CONTACT_EMAIL=contact@your-domain.com

# Used only during database seeding (npm run db:seed-admin)
# Change these before running the seeder in production
ADMIN_EMAIL=admin@caroshan.com
ADMIN_PASSWORD=ChangeThisPassword123!
ADMIN_NAME=CA Roshan
