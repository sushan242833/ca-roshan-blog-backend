NODE_ENV=test
PORT=0

# Dedicated PostgreSQL database for automated tests only.
# The test bootstrap refuses database names that do not contain "test".
DB_HOST=localhost
DB_PORT=5432
DB_NAME=roshan_blog_test
# Optional explicit override. If omitted, tests use DB_NAME when it contains
# "test"; otherwise they append "_test" to the normal DB_NAME.
# TEST_DB_NAME=roshan_blog_test
DB_USER=postgres
DB_PASSWORD=yourpassword

JWT_SECRET=test_jwt_secret
JWT_REFRESH_SECRET=test_jwt_refresh_secret

MEDIA_BASE_URL=http://localhost:4000
APP_BASE_URL=http://localhost:3000
API_BASE_URL=http://localhost:4000

EMAIL_FROM="Roshan Blog <newsletter@example.test>"
NEWSLETTER_EMAIL_RATE_LIMIT_PER_SECOND=100
